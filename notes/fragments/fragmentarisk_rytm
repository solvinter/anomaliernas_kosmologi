id: fragmentarisk_rytm

title: Fragmentarisk rytm

status: princip

type: style_rule

function:
  - beskriver_solvinters_sprakliga_andning
  - gor_rastlosheten_till_form
  - forklarar_varfor_manuset_skrivs_i_fragment
  - ger_regler_for_rendering_till_romanprosa

core_insight: >
  Rastlösheten är inte bara ett hinder för skrivandet.
  Den är också en kompositionsprincip. Fragmenten gör det
  möjligt att fånga intensiva observationer innan de stelnar,
  och senare rendera dem till kapitel, essäer, apokryfer eller
  intermezzi.

style:
  prose:
    dominant: sammanhangande_litterar_prosa

  rhythm:
    alternate:
      - langre_reflekterande_stycken
      - korta_losa_rader
      - bildfragment
      - tysta_overgangar

principles:
  - prosan_bar_berattelsen
  - de_losa_raderna_bar_tyngden
  - fragmenten_ska_inte_alltid_forklaras
  - en_ensam_mening_ska_fa_eka
  - aldrig_fragmentera_allt
  - aldrig_forklara_samma_sak_tva_ganger
  - lat_miljon_bara_filosofin
  - lat_manniskorna_bara_etiken

fragment_method:
  capture:
    - skriv_snabbt
    - spara_bilder
    - spara_meningar_som_branner
    - spara_roster_och_platser

  render:
    - valj_fragmentets_funktion
    - bestam_om_det_ar_kapitel_intermezzo_eller_apokryf
    - bygg_sammanhangande_prosa_runt_de_starkaste_bilderna
    - behall_ensamma_rader_dar_tanken_behover_andas

forms:
